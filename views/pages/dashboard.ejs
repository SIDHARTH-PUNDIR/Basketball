<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Dashboard - CourtX</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
   /* TOURNAMENT SECTION */

.tournament-container {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
  gap: 20px;
  margin-top: 20px;
}

/* CARD */
.tournament-card {
  position: relative;
  padding: 18px;
  border-radius: 16px;

  background: linear-gradient(145deg, #0c1020, #0a0d18);
  border: 1px solid rgba(255,255,255,0.05);

  transition: 0.3s ease;
  overflow: hidden;
}

/* GLOW EFFECT */
.tournament-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top left, rgba(255,122,24,0.15), transparent);
  opacity: 0;
  transition: 0.3s;
}

.tournament-card:hover::before {
  opacity: 1;
}

.tournament-card:hover {
  transform: translateY(-6px) scale(1.02);
  border-color: rgba(255,122,24,0.3);
  box-shadow: 0 15px 35px rgba(0,0,0,0.6);
}

/* HEADER */
.tournament-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tournament-header h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 20px;
  letter-spacing: 1px;
  color: white;
}

/* BADGE */
.t-badge {
  font-size: 10px;
  padding: 4px 8px;
  border-radius: 6px;
  background: rgba(255,122,24,0.15);
  color: #ff7a18;
  font-weight: 700;
  letter-spacing: 1px;
}

/* LOCATION */
.t-location {
  margin-top: 10px;
  font-size: 13px;
  color: #6c728a;
}

/* FOOTER */
.t-footer {
  margin-top: 18px;
}

/* BUTTON */
.join-btn {
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  border: none;

  background: linear-gradient(135deg, #ff7a18, #ff9a3c);
  color: white;

  font-weight: 700;
  letter-spacing: 1px;
  cursor: pointer;

  transition: 0.25s;
}

.join-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(255,122,24,0.4);
}

/* JOINED STATE */
.join-btn.joined {
  background: #1e2235;
  color: #4a5068;
  cursor: not-allowed;
  border: 1px solid #2a2d3e;
}
  </style>
</head>

<body>

<div class="page">

  <%- include("../partials/navbar") %>

  <section class="dashboard">

    <div class="dashboard-container">

      <!-- HERO -->
      <div class="dashboard-hero">
        <h1><%= user.team %></h1>
        <p>Manage your team and dominate the court 🏀</p>
      </div>

      <!-- ACTION CARDS -->
      <div class="dashboard-actions">

        <div class="action-card">
          <h3>Live Games</h3>
          <p>Watch ongoing matches</p>
          <a href="/live" class="action-btn">View</a>
        </div>

        <div class="action-card">
          <h3>Team Statistics</h3>
          <p>View performance and analytics</p>
          <a href="/stats" class="action-btn secondary">View Stats</a>
        </div>

      </div>



      <!-- STATS -->
      <h3 class="section-title">Team Stats</h3>

      <div class="stats-container">

        <div class="stat-card">
          <h4>🏆 Wins</h4>
          <p>12</p>
        </div>

        <div class="stat-card">
          <h4>❌ Losses</h4>
          <p>3</p>
        </div>

        <div class="stat-card">
          <h4>🏀 Points</h4>
          <p>945</p>
        </div>

        <div class="stat-card">
          <h4>📈 Rank</h4>
          <p>#2</p>
        </div>

      </div>

      <!-- COURT -->
      <h3 class="section-title">Starting Lineup</h3>

      <div class="court">

        <% const PG = players.find(p => p.position === "PG"); %>
        <% const SG = players.find(p => p.position === "SG"); %>
        <% const SF = players.find(p => p.position === "SF"); %>
        <% const PF = players.find(p => p.position === "PF"); %>
        <% const C  = players.find(p => p.position === "C"); %>

        <% if(C){ %>
        <div class="position c">
          <img src="<%= C.image %>">
          <span><%= C.name %></span>
          <span class="pos">C</span>
        </div>
        <% } %>

        <% if(PF){ %>
        <div class="position pf">
          <img src="<%= PF.image %>">
          <span><%= PF.name %></span>
          <span class="pos">PF</span>
        </div>
        <% } %>

        <% if(SF){ %>
        <div class="position sf">
          <img src="<%= SF.image %>">
          <span><%= SF.name %></span>
          <span class="pos">SF</span>
        </div>
        <% } %>

        <% if(PG){ %>
        <div class="position pg">
          <img src="<%= PG.image %>">
          <span><%= PG.name %></span>
          <span class="pos">PG</span>
        </div>
        <% } %>

        <% if(SG){ %>
        <div class="position sg">
          <img src="<%= SG.image %>">
          <span><%= SG.name %></span>
          <span class="pos">SG</span>
        </div>
        <% } %>

      </div>

      <!-- POSITION POPUP -->
      <div id="position-popup" class="position-popup">
        <p>Select Position</p>
        <button onclick="assignPosition('PG')">PG</button>
        <button onclick="assignPosition('SG')">SG</button>
        <button onclick="assignPosition('SF')">SF</button>
        <button onclick="assignPosition('PF')">PF</button>
        <button onclick="assignPosition('C')">C</button>
      </div>

      <!-- TEAM HEADER -->
      <div class="team-header">
        <h3 class="section-title">Team Members</h3>
        <a href="/add-player" class="add-player-btn">+ Add Player</a>
      </div>

      <!-- TEAM MEMBERS -->
      <div class="team-container">

        <% if(players.length === 0){ %>
          <p class="empty-state">No players added yet</p>
        <% } %>

        <% players.forEach(player => { %>

        <div class="player-card" data-id="<%= player.id %>" onclick="selectPlayer(this)">

          <form action="/remove-player/<%= player.id %>" method="POST">
            <button type="submit" class="remove-player">×</button>
          </form>

          <img src="<%= player.image %>" class="player-img">

          <h4 class="player-name"><%= player.name %></h4>

          <div class="player-info">
            <span class="player-role"><%= player.role %></span>

            <% if(player.position){ %>
              <span class="player-position"><%= player.position %></span>
            <% } %>
          </div>

        </div>

        <% }) %>

      </div>

      
 <h3 class="section-title">Available Tournaments</h3>
<%
const registeredIds = registered.map(r => r.tournament_id);
%>
<div class="tournament-container">

  <% tournaments.forEach(t => { %>

    <div class="tournament-card" onclick="window.location.href='/tournaments/<%= t.id %>'" style="cursor:pointer;">

      <div class="tournament-header">
        <h4><%= t.name %></h4>
        <span class="t-badge">OPEN</span>
      </div>

      <p class="t-location">📍 <%= t.location %></p>

      <div class="t-footer">

        <% if (registeredIds.includes(t.id)) { %>
          <button class="join-btn joined" onclick="event.stopPropagation()">✓ Joined</button>
        <% } else { %>
          <form action="/tournaments/<%= t.id %>/register" method="POST" onclick="event.stopPropagation()">
            <button class="join-btn">Join Tournament</button>
          </form>
        <% } %>

      </div>

    </div>

  <% }) %>

</div>


    </div>

  </section>

</div>

<!-- JS -->
<script>

let selectedPlayer = null;

function selectPlayer(el){
  selectedPlayer = el.getAttribute("data-id");
  document.getElementById("position-popup").style.display = "block";
}

function assignPosition(pos){
  fetch("/assign-position", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      playerId: selectedPlayer,
      position: pos
    })
  }).then(() => location.reload());
}

document.addEventListener("click", function(e){
  const popup = document.getElementById("position-popup");

  if(!popup.contains(e.target) && !e.target.closest(".player-card")){
    popup.style.display = "none";
  }
});

</script>

</body>
</html>