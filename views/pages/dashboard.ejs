
<head>
<meta charset="UTF-8">
<title>Dashboard - CourtX</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="stylesheet" href="/css/styles.css">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

</head>
<body>
    <div class="page">
<%- include("../partials/navbar") %>




<section class="dashboard">

<div class="dashboard-container">

<h2 class="dashboard-title">
Welcome <%= user.team %> 👋
</h2>


<!-- ACTION CARDS -->
<div class="dashboard-actions">

<div class="action-card">
<h3>Live Games</h3>
<p>Watch ongoing matches</p>
<a href="/live" class="action-btn">View</a>
</div>

<div class="action-card">
<h3>Team Statistics</h3>
<p>View performance and analytics</p>
<a href="/stats" class="action-btn secondary">View Stats</a>
</div>


</div>

<!-- Stats-->

<h3 class="section-title">Team Stats</h3>

<div class="stats-container">

<div class="stat-card">
<h4>Wins</h4>
<p>12</p>
</div>

<div class="stat-card">
<h4>Losses</h4>
<p>3</p>
</div>

<div class="stat-card">
<h4>Points</h4>
<p>945</p>
</div>

<div class="stat-card">
<h4>Rank</h4>
<p>#2</p>
</div>

</div>


<!-- position-->
<h3 class="section-title">Starting Lineup</h3>

<div class="court">

<% const PG = players.find(p => p.position === "PG"); %>
<% const SG = players.find(p => p.position === "SG"); %>
<% const SF = players.find(p => p.position === "SF"); %>
<% const PF = players.find(p => p.position === "PF"); %>
<% const C  = players.find(p => p.position === "C"); %>
<% if(C){ %>
<div class="position c">
<img src="<%= C.image %>">
<span><%= C.name %></span>
<span class="pos"><%= C.position %></span>
</div>
<% } %>

<% if(PF){ %>
<div class="position pf">
<img src="<%= PF.image %>">
<span><%= PF.name %></span>
<span class="pos"><%= PF.position %></span>
</div>
<% } %>

<% if(SF){ %>
<div class="position sf">
<img src="<%= SF.image %>">
<span><%= SF.name %></span>
<span class="pos"><%= SF.position %></span>
</div>
<% } %>

<% if(PG){ %>
<div class="position pg">
<img src="<%= PG.image %>">
<span><%= PG.name %></span>
<span class="pos"><%= PG.position %></span>
</div>
<% } %>

<% if(SG){ %>
<div class="position sg">
<img src="<%= SG.image %>">
<span><%= SG.name %></span>
<span class="pos"><%= SG.position %></span>
</div>
<% } %>
</div>

<!-- Team Members Section -->
 <div id="position-popup" class="position-popup">
  <p>Select Position</p>
  <button onclick="assignPosition('PG')">PG</button>
  <button onclick="assignPosition('SG')">SG</button>
  <button onclick="assignPosition('SF')">SF</button>
  <button onclick="assignPosition('PF')">PF</button>
  <button onclick="assignPosition('C')">C</button>
</div>

<div class="team-header">

<h3 class="section-title">Team Members</h3>

<a href="/add-player" class="add-player-btn">
+ Add Player
</a>

</div>

<div class="team-container">

<% players.forEach(player => { %>

<div class="player-card" data-id="<%= player.id %>" onclick="selectPlayer(this)">

<form action="/remove-player/<%= player.id %>" method="POST">
<button type="submit" class="remove-player">×</button>
</form>

<img src="<%= player.image %>" class="player-img">

<h4 class="player-name"><%= player.name %></h4>

<div class="player-info">
<span class="player-role"><%= player.role %></span>

<% if(player.position){ %>
<span class="player-position"><%= player.position %></span>
<% } %>
</div>

</div>
<% }) %>

</div>
<!-- ACTIVE TOURNAMENTS -->

<h3 class="section-title">Active Tournaments</h3>

<div class="tournaments">

<div class="tournament-card">
<h4>Spring Cup</h4>
<p>March 2026</p>
</div>

<div class="tournament-card">
<h4>Summer League</h4>
<p>June 2026</p>
</div>

<div class="tournament-card">
<h4>City Championship</h4>
<p>August 2026</p>
</div>

</div>

</div>

</section>

<script>
let selectedPlayer = null;

function selectPlayer(el){
    const positions = {
  PG: { top: "75%", left: "50%" },
  SG: { top: "65%", left: "75%" },
  SF: { top: "65%", left: "25%" },
  PF: { top: "50%", left: "70%" },
  C:  { top: "50%", left: "50%" }
};
  const id = el.getAttribute("data-id");
  selectedPlayer = id;
  document.getElementById("position-popup").style.display = "block";
}

function assignPosition(pos){
  fetch("/assign-position", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      playerId: selectedPlayer,
      position: pos
    })
  })
  .then(() => location.reload());
}

function placePlayer(playerId, position) {
  const player = document.getElementById(playerId);
  const court = document.querySelector(".court");

  // Move player into court
  court.appendChild(player);

  // Apply position
  player.style.position = "absolute";
  player.style.top = positions[position].top;
  player.style.left = positions[position].left;
}
document.addEventListener("click", function(e){

  const popup = document.getElementById("position-popup");

  if(!popup.contains(e.target) && !e.target.closest(".player-card")){
    popup.style.display = "none";
  }

});
</script>



  

    </div>


</body>
