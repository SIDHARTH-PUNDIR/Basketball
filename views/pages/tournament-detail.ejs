<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= tournament.name %></title>
  <link rel="stylesheet" href="/css/styles.css">
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">
  <style>/* =========================
   GLOBAL
========================= */
body { 
  background: #0b0d17; 
  color: #e8eaf0; 
  font-family: 'Barlow', sans-serif; 
  line-height: 1.6;
}

/* =========================
   HERO SECTION
========================= */
.t-hero {
  padding: 80px 60px;
  background: radial-gradient(circle at top left, #1a1c2c, #0b0d17);
  border-bottom: 1px solid rgba(255,122,24,0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.t-hero h1 {
  font-family: 'Anton', sans-serif;
  font-size: 48px;
  letter-spacing: 2px;
  color: white;
}

.t-hero-meta {
  margin-top: 10px;
  display: flex;
  gap: 24px;
}

.t-hero-meta span {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #4a5068;
}

.t-hero-meta span strong { color: #ff7a18; }

/* =========================
   BUTTONS
========================= */
.register-btn {
  background: #ff7a18;
  color: white;
  border: none;
  padding: 14px 30px;
  border-radius: 10px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: 0.25s;
  text-decoration: none;
}

.register-btn:hover {
  background: #ff8f32;
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(255,122,24,0.4);
}

.register-btn.disabled {
  background: #1e2030;
  color: #4a5068;
  cursor: not-allowed;
  border: 1px solid #2a2d3e;
}

.action-btn {
  background: linear-gradient(90deg, #ff7a18, #ff8f32);
  border: none;
  padding: 10px 18px;
  border-radius: 8px;
  color: white;
  cursor: pointer;
  font-weight: 600;
  transition: 0.2s;
}

.action-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(255,122,24,0.4);
}

.danger-btn {
  background: linear-gradient(90deg, #ff3b3b, #ff5c5c);
  border: none;
  padding: 12px 15px;
  border-radius: 8px;
  color: white;
  cursor: pointer;
}

/* =========================
   ADMIN PANEL
========================= */
.admin-controls {
  max-width: 1300px;
  margin: 30px auto;
  padding: 20px;

  display: flex;
  align-items: center;
  gap: 15px;
  flex-wrap: wrap;

  background: rgba(20, 24, 40, 0.6);
  border-radius: 14px;
  border: 1px solid rgba(255,122,24,0.15);

}

/* INPUT FIX */
.admin-controls input {
  padding: 10px 12px;
  border-radius: 6px;
  border: 1px solid rgba(255,255,255,0.1);
  background: #0f1324;
  color: white;
  width: 180px;
}

/* BUTTON GROUP FEEL */
.admin-controls form {
  display: flex;
  align-items: center;
  gap: 10px;
}
/* =========================
   BODY LAYOUT
========================= */
.t-body {
  max-width: 1300px;
  margin: 0 auto;
  padding: 40px 20px;
}

/* FIXTURES FULL WIDTH */
.fixtures-full {
  margin-bottom: 50px;
}

/* LOWER GRID */
.bottom-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 30px;
}

/* =========================
   SECTION TITLE
========================= */
.section-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #ff7a18;
  margin-bottom: 25px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-title::after {
  content: "";
  flex: 1;
  height: 1px;
  background: rgba(255, 122, 24, 0.2);
}

/* =========================
   FIXTURES (NEW)
========================= */
.round-block {
  margin-bottom: 30px;
}

.round-title {
  font-size: 12px;
  letter-spacing: 2px;
  color: #ff7a18;
  margin-bottom: 10px;
  font-weight: 700;
}
.fixture-select {
  padding: 10px;
  border-radius: 6px;
  background: #0f1324;
  color: white;
  border: 1px solid rgba(255,255,255,0.1);
}
.fixture-row {
  display: flex;
  justify-content: space-between;
  align-items: center;

  padding: 15px 20px;
  margin-bottom: 10px;

  background: rgba(255,255,255,0.03);
  border-radius: 10px;
  border-left: 3px solid rgba(255,122,24,0.4);
}

/* TEAMS */
.fixture-row .teams {
  font-weight: 700;
  font-size: 15px;
  width: 40%;
}

.fixture-row .vs {
  margin: 0 8px;
  color: #555;
}

/* SCORE */
.center-info {
  width: 20%;
  text-align: center;
}

.score {
  font-size: 18px;
  font-weight: 800;
}

.score.muted {
  color: #555;
}

/* RIGHT */
.right-info {
  width: 40%;
  text-align: right;
  font-size: 12px;
}

/* STATUS */
.status {
  font-weight: 700;
  margin-top: 5px;
}

.status.live { color: #ff4545; }
.status.final { color: #22c55e; }
.status.upcoming { color: #888; }

/* =========================
   CARD PANEL
========================= */
.card-panel {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16px;
  padding: 24px;
}

/* =========================
   TABLE
========================= */
.leaderboard-table {
  width: 100%;
  border-collapse: collapse;
}

.leaderboard-table th {
  font-size: 11px;
  color: #4a5068;
  padding: 10px;
}

.leaderboard-table td {
  padding: 12px 10px;
  border-bottom: 1px solid rgba(255,255,255,0.03);
}

/* =========================
   TEAMS
========================= */
.team-row {
  display: flex;
  align-items: center;
  padding: 10px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.team-rank {
  width: 30px;
  color: #666;
}

.team-name {
  flex: 1;
  font-weight: 600;
}

/* REMOVE BTN */
.danger-btn-mini {
  background: rgba(255, 69, 69, 0.1);
  color: #ff4545;
  border: 1px solid rgba(255, 69, 69, 0.2);
  width: 24px;
  height: 24px;
  border-radius: 50%;
  cursor: pointer;
}

/* =========================
   SLOTS
========================= */
.slots-left {
  text-align: center;
  margin-top: 16px;
  font-size: 12px;
  letter-spacing: 2px;
  color: #4a5068;
}

.slots-left strong { color: #ff7a18; }

/* =========================
   EMPTY
========================= */
.no-fixtures {
  text-align: center;
  padding: 40px;
  color: #2a2d3e;
  font-size: 14px;
  letter-spacing: 2px;
  background: rgba(255,255,255,0.02);
  border-radius: 12px;
}

/* =========================
   FORM INPUT
========================= */
.quick-update-form {
  display: flex;
  gap: 8px;
  margin-top: 5px;
}

.quick-update-form input {
  width: 40px;
  height: 30px;
  background: #161821;
  border: 1px solid rgba(255, 122, 24, 0.3);
  color: white;
  text-align: center;
}

.top-grid {
  display: grid;
  grid-template-columns: 1fr 1fr; /* equal width */
  gap: 30px;
  align-items: start;
}
  </style>
</head>
<body>

<%- include("../partials/navbar") %>

<!-- HERO -->
<div class="t-hero">
  <div>
    <h1><%= tournament.name.toUpperCase() %></h1>
    <div class="t-hero-meta">
      <span>📍 <strong><%= tournament.location %></strong></span>
      <span>📅 <strong>
        <%= new Date(tournament.start_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
        —
        <%= new Date(tournament.end_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
      </strong></span>
      <span>👥 <strong><%= teams.length %> / <%= tournament.max_teams %></strong> teams</span>
    </div>
  </div>

  <% if (!user) { %>
    <a href="/login" class="register-btn">Sign In to Register</a>
  <% } else if (isRegistered) { %>
    <span class="register-btn disabled">✓ Registered</span>
  <% } else if (teams.length >= tournament.max_teams) { %>
    <span class="register-btn disabled">Tournament Full</span>
  <% } else { %>
    <form action="/tournaments/<%= tournament.id %>/register" method="POST">
      <button type="submit" class="register-btn">Register Team</button>
    </form>
  <% } %>
</div>





<% if (user && (user.is_admin || user.id === tournament.created_by)) { %>

<div class="admin-controls">
  
  <!-- DELETE TOURNAMENT -->
  <form action="/tournaments/<%= tournament.id %>/delete" method="POST">
    <button 
  class="danger-btn" 
  onclick="return confirm('Are you sure you want to delete this tournament?')">
  Delete Tournament
</button>
  </form>

  <!-- GENERATE FIXTURES -->
<form action="/admin/generate-fixtures/<%= tournament.id %>" method="POST">

  <select name="type" class="fixture-select">
    <option value="round">Round Robin</option>
    <option value="knockout">Knockout</option>
  </select>

  <button class="action-btn">Generate Fixtures</button>
</form>

  <!-- ADD TEAM -->
  <form action="/tournaments/<%= tournament.id %>/add-team" method="POST" onsubmit="return validateTeam()">
    <input 
  type="text" 
  id="teamSearch" 
  placeholder="Search team..." 
  autocomplete="off">

<input type="hidden" name="team_id" id="teamId">

<div id="suggestions" class="suggestions-box"></div>
    <button class="action-btn">Add Team</button>
  </form>

</div>

<% } %>

<!-- BODY -->

<div class="t-body">

  <!-- 🔥 TOP GRID (STANDINGS + TEAMS) -->
  <div class="top-grid">

    <!-- 🏆 STANDINGS -->
    <div>
      <div class="section-title">Standings</div>

      <div class="card-panel">
        <% if (leaderboard.length === 0) { %>
          <div class="no-fixtures">STANDINGS WILL UPDATE AFTER FIRST MATCH</div>
        <% } else { %>

          <table class="leaderboard-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Team</th>
                <th>MP</th>
                <th>W</th>
                <th>L</th>
                <th style="color:#ff7a18">Pts</th>
              </tr>
            </thead>

            <tbody>
              <% leaderboard.forEach((t, i) => { %>
                <tr>
                  <td><span class="rank-pill"><%= i + 1 %></span></td>
                  <td><%= t.team_name %></td>
                  <td><%= t.matches_played %></td>
                  <td><%= t.wins %></td>
                  <td><%= t.losses %></td>
                  <td style="color:#ff7a18"><%= t.points %></td>
                </tr>
              <% }) %>
            </tbody>

          </table>

        <% } %>
      </div>
    </div>


    <!-- 👥 TEAMS -->
    <div>
      <div class="section-title">Teams</div>

      <div class="card-panel">

        <% teams.forEach((t, i) => { %>
          <div class="team-row">
            <span class="team-rank">#<%= i + 1 %></span>
            <span class="team-name"><%= t.team_name %></span>

            <% if (user && (user.is_admin || user.id === tournament.created_by)) { %>
              <form action="/tournaments/<%= tournament.id %>/remove-team/<%= t.id %>" method="POST">
                <button class="danger-btn-mini">✕</button>
              </form>
            <% } %>
          </div>
        <% }) %>

        <div class="slots-left">
          <strong><%= tournament.max_teams - teams.length %></strong> slots remaining
        </div>

      </div>
    </div>

  </div>


  <!-- 🔥 FIXTURES BELOW -->
  <div class="fixtures-full">

    <div class="section-title">Match Fixtures</div>

    <% if (matches.length === 0) { %>
      <div class="no-fixtures">FIXTURES WILL BE ANNOUNCED SOON</div>
    <% } else { %>

      <% 
        const grouped = {};
        matches.forEach(m => {
          if (!grouped[m.round]) grouped[m.round] = [];
          grouped[m.round].push(m);
        });
      %>

      <% Object.keys(grouped).forEach(round => { %>

        <div class="round-block">
          <div class="round-title"><%= round %></div>

          <% grouped[round].forEach(match => { %>

            <div class="fixture-row">

              <div class="teams">
                <span><%= match.teama %></span>
                <span class="vs">VS</span>
                <span><%= match.teamb %></span>
              </div>

              <div class="center-info">
                <% if (match.status === 'FINAL' || match.status === 'LIVE') { %>
                  <div class="score"><%= match.scorea %> - <%= match.scoreb %></div>
                <% } else { %>
                  <div class="score muted">TBD</div>
                <% } %>
              </div>

              <div class="right-info">
                <div class="date">
                  <%= match.match_date 
                    ? new Date(match.match_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) 
                    : 'TBD' %>
                </div>

                <div class="status <%= match.status.toLowerCase() %>">
                  <%= match.status %>
                </div>

                <% if (user && (user.is_admin || user.id === tournament.created_by) && match.status !== 'FINAL') { %>
                  <form action="/matches/<%= match.id %>/result" method="POST" class="quick-update-form">
                    <input type="number" name="scoreA" placeholder="A" required>
                    <input type="number" name="scoreB" placeholder="B" required>
                    <button class="action-btn">✔</button>
                  </form>
                <% } %>
              </div>

            </div>

          <% }) %>
        </div>

      <% }) %>

    <% } %>

  </div>

</div><!-- ✅ CLOSE t-body -->
<script>
const allTeams = <%- JSON.stringify(users || []) %>;

const input = document.getElementById("teamSearch");
const suggestions = document.getElementById("suggestions");
const hiddenInput = document.getElementById("teamId");

input.addEventListener("input", () => {
  hiddenInput.value = "";  // reset

  const value = input.value.toLowerCase().trim();
  suggestions.innerHTML = "";

  if (!value) return;

  const filtered = allTeams.filter(t => {
    return t.team && t.team.toLowerCase().includes(value);
  });

  filtered.forEach(t => {
    const div = document.createElement("div");
    div.innerText = t.team;

    div.onclick = () => {
      input.value = t.team;
      hiddenInput.value = t.id;
      suggestions.innerHTML = "";
    };

    suggestions.appendChild(div);
  });
});
</script>

</body>
</html>